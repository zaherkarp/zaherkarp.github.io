#!/usr/bin/env bash
# Pre-push checks for zaherkarp.github.io.
# Mirrors CLAUDE.md §Pre-push checks. Activated automatically by
# scripts/_common.py:install_git_hooks() on first run of any project
# script (core.hooksPath -> scripts/hooks).
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

failures=0

fail() { echo "  FAIL: $1" >&2; failures=$((failures + 1)); }
ok()   { echo "  ok:   $1"; }

echo "Running pre-push checks..." >&2

# Redundancy short-circuit: if scripts/blog.config.yaml has
# redundancy.prepush_lint = skip-if-cli-linted AND every commit in the
# push range carries the Blog-CLI-Linted: trailer (written by `blog
# publish`), the three lint blocks below are skipped. Toggle defaults
# to `always` (legacy stays active); manage via
# `blog config set prepush_lint skip|always`.
#
# git's pre-push contract: one line per ref on stdin, formatted
# "<local_ref> <local_sha> <remote_ref> <remote_sha>". For each ref we
# pass (remote_sha, local_sha) to redundancy.py so it can walk
# `git rev-list remote..local` and require trailers on EVERY commit, not
# just HEAD. New-branch pushes (remote_sha = zeros) and force-pushes
# with unresolvable ranges fall back to "run lints" inside redundancy.py.
RANGE_ARGS=()
if [ ! -t 0 ]; then
  while read -r _local_ref local_sha _remote_ref remote_sha; do
    [ -z "$local_sha" ] && continue
    RANGE_ARGS+=("--range" "$remote_sha" "$local_sha")
  done
fi
# If multiple refs were pushed, every --range pair stacks; redundancy.py
# only short-circuits when ALL ranges check out.

CLI_LINTED=false
if [ ${#RANGE_ARGS[@]} -gt 0 ]; then
  if python scripts/redundancy.py prepush_lint "${RANGE_ARGS[@]}" 2>/dev/null; then
    CLI_LINTED=true
    ok "lint_blog/lint_vocab/lint_facts skipped (every commit in push range CLI-linted, toggle on)"
  fi
else
  # Manual invocation outside the hook context (stdin is a tty or empty).
  # Fall back to HEAD-only check.
  if python scripts/redundancy.py prepush_lint 2>/dev/null; then
    CLI_LINTED=true
    ok "lint_blog/lint_vocab/lint_facts skipped (HEAD CLI-linted, toggle on; no push range)"
  fi
fi

if [ "$CLI_LINTED" = "false" ]; then
  # 1. Blog source-side lint (HTML comments, blockquote-as-diagram,
  #    blank line inside <svg>, etc).
  if compgen -G "src/content/blog/*.md" >/dev/null; then
    if output=$(python scripts/lint_blog.py 2>&1); then
      ok "lint_blog clean"
    else
      echo "$output" >&2
      fail "lint_blog"
    fi
  fi

  # 2. Vocabulary lint (canonical CMS program-name capitalization across
  #    blog sources, resume, index.html). See CLAUDE.md §Vocabulary.
  if output=$(python scripts/lint_vocab.py 2>&1); then
    ok "lint_vocab clean"
  else
    echo "$output" >&2
    fail "lint_vocab"
  fi

  # 3. Cross-surface fact lint (resume.md vs index.html h3+meta vs JSON-LD).
  #    Playbook for failures: scripts/lint_facts.md.
  if [ -f src/content/resume.md ] && [ -f index.html ]; then
    if output=$(python scripts/lint_facts.py 2>&1); then
      ok "lint_facts clean"
    else
      echo "$output" >&2
      fail "lint_facts"
    fi
  fi
fi

# 4. Em-dash chrome cleanliness — homepage must be em-dash-clean.
if [ -f index.html ]; then
  em_count=$(grep -c '—' index.html || true)
  if [ "$em_count" = "0" ]; then
    ok "em-dash chrome clean"
  else
    fail "em-dash found in index.html ($em_count occurrence(s))"
  fi

  # 5. Accent discipline — Tufte 1-2x per chart rule, soft cap at 8.
  accent_count=$(grep -cE -- '--accent' index.html || true)
  if [ "$accent_count" -le 8 ]; then
    ok "accent discipline ($accent_count uses, cap 8)"
  else
    fail "--accent appears $accent_count times in index.html (cap is 8)"
  fi
fi

# 6. SVG blank-line trap in built blog HTML — markdown-it wraps SVG
#    children in <p> when a blank line breaks the HTML block.
if [ -d blog ]; then
  if grep -rE '<p><(text|line|polyline|circle|rect|polygon)' blog/ >/dev/null 2>&1; then
    fail "<p>-wrapped SVG children in blog/ (blank line inside <svg>)"
  else
    ok "no <p>-wrapped SVG children in blog/"
  fi
fi

if [ "$failures" -gt 0 ]; then
  echo "" >&2
  echo "$failures pre-push check(s) failed. See CLAUDE.md §Pre-push checks." >&2
  echo "(bypass: git push --no-verify — only if you know why)" >&2
  exit 1
fi

echo "all pre-push checks passed" >&2

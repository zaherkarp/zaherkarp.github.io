#!/usr/bin/env bash
# Pre-push checks for zaherkarp.github.io.
# Mirrors CLAUDE.md §Pre-push checks. Activated automatically by
# scripts/_common.py:install_git_hooks() on first run of any project
# script (core.hooksPath -> scripts/hooks).
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Resolve a Python interpreter that has the lint deps. Prefer a repo-local
# .venv (create with: python3 -m venv .venv && .venv/bin/pip install -r
# scripts/requirements.txt), then a `python` on PATH, then `python3`.
# Modern macOS ships only `python3`, so a bare `python` call would fail
# with "command not found" and every lint would be skipped as a failure.
if [ -x ".venv/bin/python" ]; then
  PY=".venv/bin/python"
elif command -v python >/dev/null 2>&1; then
  PY="python"
elif command -v python3 >/dev/null 2>&1; then
  PY="python3"
else
  echo "  FAIL: no python interpreter found (install python3)" >&2
  exit 1
fi

failures=0

fail() { echo "  FAIL: $1" >&2; failures=$((failures + 1)); }
ok()   { echo "  ok:   $1"; }

echo "Running pre-push checks..." >&2

# Redundancy short-circuit: if scripts/blog.config.yaml has
# redundancy.prepush_lint = skip-if-cli-linted AND every commit in the
# push range carries the Blog-CLI-Linted: trailer (written by `blog
# publish`), the three lint blocks below are skipped. Toggle defaults
# to `always` (legacy stays active); manage via
# `blog config set prepush_lint skip|always`.
#
# git's pre-push contract: one line per ref on stdin, formatted
# "<local_ref> <local_sha> <remote_ref> <remote_sha>". For each ref we
# pass (remote_sha, local_sha) to redundancy.py so it can walk
# `git rev-list remote..local` and require trailers on EVERY commit, not
# just HEAD. New-branch pushes (remote_sha = zeros) and force-pushes
# with unresolvable ranges fall back to "run lints" inside redundancy.py.
RANGE_ARGS=()
if [ ! -t 0 ]; then
  while read -r _local_ref local_sha _remote_ref remote_sha; do
    [ -z "$local_sha" ] && continue
    RANGE_ARGS+=("--range" "$remote_sha" "$local_sha")
  done
fi
# If multiple refs were pushed, every --range pair stacks; redundancy.py
# only short-circuits when ALL ranges check out.

CLI_LINTED=false
if [ ${#RANGE_ARGS[@]} -gt 0 ]; then
  if "$PY" scripts/redundancy.py prepush_lint "${RANGE_ARGS[@]}" 2>/dev/null; then
    CLI_LINTED=true
    ok "lint_blog/lint_vocab/lint_facts skipped (every commit in push range CLI-linted, toggle on)"
  fi
else
  # Manual invocation outside the hook context (stdin is a tty or empty).
  # Fall back to HEAD-only check.
  if "$PY" scripts/redundancy.py prepush_lint 2>/dev/null; then
    CLI_LINTED=true
    ok "lint_blog/lint_vocab/lint_facts skipped (HEAD CLI-linted, toggle on; no push range)"
  fi
fi

if [ "$CLI_LINTED" = "false" ]; then
  # 1. Blog source-side lint (HTML comments, blockquote-as-diagram,
  #    blank line inside <svg>, etc).
  if compgen -G "src/content/blog/*.md" >/dev/null; then
    if output=$("$PY" scripts/lint_blog.py 2>&1); then
      ok "lint_blog clean"
    else
      echo "$output" >&2
      fail "lint_blog"
    fi
  fi

  # 2. Vocabulary lint (canonical CMS program-name capitalization across
  #    blog sources, resume, index.html). See CLAUDE.md §Vocabulary.
  if output=$("$PY" scripts/lint_vocab.py 2>&1); then
    ok "lint_vocab clean"
  else
    echo "$output" >&2
    fail "lint_vocab"
  fi

  # 3. Cross-surface fact lint (resume.md vs index.html h3+meta vs JSON-LD).
  #    Playbook for failures: scripts/lint_facts.md.
  if [ -f src/content/resume.md ] && [ -f index.html ]; then
    if output=$("$PY" scripts/lint_facts.py 2>&1); then
      ok "lint_facts clean"
    else
      echo "$output" >&2
      fail "lint_facts"
    fi
  fi
fi

# 3b. Note additivity lint (sidenote/margin-note redundancy against
#     page prose, homepageMarginnote vs title/description, and
#     publications.yaml note vs venue/year). Runs outside the CLI
#     short-circuit above because the blog CLI's lint set does not
#     include it. See CLAUDE.md §Sidenote system (additivity rule).
if [ -f scripts/lint_notes.py ]; then
  if output=$("$PY" scripts/lint_notes.py 2>&1); then
    ok "lint_notes clean"
  else
    echo "$output" >&2
    fail "lint_notes"
  fi
fi

# 3c. Recognition alignment lint (homepage #service Service and
#     Recognition entries must each have a counterpart in cv.md's
#     Awards / Fellowships / Service record). The gate blocks a push
#     when the two hand-authored surfaces drift; the (non-failing)
#     coverage report of CV-only items is shown on a manual
#     `"$PY" scripts/lint_recognition.py` run. See CLAUDE.md
#     §Recognition alignment lint.
if [ -f scripts/lint_recognition.py ] && [ -f src/content/cv.md ]; then
  if output=$("$PY" scripts/lint_recognition.py 2>&1); then
    ok "lint_recognition clean"
  else
    echo "$output" >&2
    fail "lint_recognition"
  fi
fi

# 3d. Gantt figure alignment lint (the homepage Education + Service
#     Gantt figure must carry a mark for every #education and #service
#     entry). Guards the figure against falling out of date when a
#     section grows. See CLAUDE.md §Gantt figure alignment lint.
if [ -f scripts/lint_gantt.py ] && [ -f index.html ]; then
  if output=$("$PY" scripts/lint_gantt.py 2>&1); then
    ok "lint_gantt clean"
  else
    echo "$output" >&2
    fail "lint_gantt"
  fi
fi

# 3e. Marker-integrity lint (the build-time injection markers a
#     generator splices into -- activity-grid, writing-list, pub-list,
#     cliff-path, blog-thoughts, the cv.md publications placeholder, etc.
#     -- must pair cleanly and still be present). Guards the
#     marker-injection pattern against a stray hand edit that deletes or
#     crosses a pair. See docs/pipelines.md §marker-injection pattern.
if [ -f scripts/lint_markers.py ]; then
  if output=$("$PY" scripts/lint_markers.py 2>&1); then
    ok "lint_markers clean"
  else
    echo "$output" >&2
    fail "lint_markers"
  fi
fi

# 3f. Skills consistency lint (resume.md's generated Skills block must
#     match what skills.yaml -- the source of truth -- would generate via
#     render_resume_skills). build_resume regenerates + commits resume.md
#     on main, but not on PRs, so this gate keeps the two from drifting
#     before the next build. See CLAUDE.md §Resume and CV pipeline.
if [ -f scripts/lint_skills.py ] && [ -f src/content/skills.yaml ]; then
  if output=$("$PY" scripts/lint_skills.py 2>&1); then
    ok "lint_skills clean"
  else
    echo "$output" >&2
    fail "lint_skills"
  fi
fi

# 4. Em-dash chrome cleanliness — index.html, resume.md, cv.md, and the
#    life-in-weeks grid must be em-dash-clean. Blog markdown is exempt
#    (preserves historical voice); resume + CV render to PDFs handed to
#    recruiters, and life-in-weeks is generated/hand-authored chrome, so all
#    share the chrome register with the homepage. (Generated blog "thoughts"
#    are em-dash-stripped at the source; this guards hand-authored milestones.)
em_total=0
em_report=""
em_surfaces=0
for f in index.html src/content/resume.md src/content/cv.md life-in-weeks/index.html; do
  if [ -f "$f" ]; then
    em_surfaces=$((em_surfaces + 1))
    n=$(grep -c '—' "$f" || true)
    em_total=$((em_total + n))
    [ "$n" -gt 0 ] && em_report="$em_report\n    $f: $n"
  fi
done
if [ "$em_surfaces" -gt 0 ]; then
  if [ "$em_total" = "0" ]; then
    ok "em-dash chrome clean ($em_surfaces surface(s))"
  else
    echo -e "em-dash found in chrome ($em_total occurrence(s)):$em_report" >&2
    fail "em-dash chrome"
  fi
fi

if [ -f index.html ]; then
  # 5. Accent discipline — Tufte 1-2x per chart rule.
  #    Counts BOTH `--accent` (CSS variable references) AND `#7a0000`
  #    (literal hex in SVG callouts and CSS palette plumbing). The
  #    earlier version of this check only grepped `--accent`, which
  #    missed new SVG callouts that hardcode the hex instead of using
  #    the variable (a real path; the SVG palette adapter in index.html
  #    expects #7a0000 as a presentation attribute and translates it
  #    back to var(--accent) at render time, so the literal hex IS the
  #    designed pattern for SVG element attributes).
  #
  #    Cap = current accepted total + 1, set when the combined-grep
  #    landed at 19. Ratchet down when removing uses; bump only after
  #    discussion since each accent use should earn its place per
  #    CLAUDE.md §Palette.
  accent_count=$(grep -cE -- '--accent|#7a0000' index.html || true)
  if [ "$accent_count" -le 20 ]; then
    ok "accent discipline ($accent_count uses, cap 20)"
  else
    fail "--accent + #7a0000 appears $accent_count times in index.html (cap is 20)"
  fi
fi

# 6. SVG blank-line trap in built blog HTML — markdown-it wraps SVG
#    children in <p> when a blank line breaks the HTML block.
if [ -d blog ]; then
  if grep -rE '<p><(text|line|polyline|circle|rect|polygon)' blog/ >/dev/null 2>&1; then
    fail "<p>-wrapped SVG children in blog/ (blank line inside <svg>)"
  else
    ok "no <p>-wrapped SVG children in blog/"
  fi
fi

# 7. Critique-pipeline independence contract — no Anthropic SDK import
#    and no ANTHROPIC_API_KEY env var anywhere under scripts/ or
#    .github/workflows/. The critique pipeline runs via Claude Code
#    (subscription auth), not via the Anthropic API. See CLAUDE.md
#    §Critique pipeline for the full contract.
#
#    Comment-only mentions (the workflow file documents what it does
#    NOT use; this hook documents its own check) are stripped via the
#    awk pass below so the contract describes itself in plain English
#    without self-tripping.
contract_scope=()
[ -d scripts ] && contract_scope+=("scripts")
[ -d .github/workflows ] && contract_scope+=(".github/workflows")
if [ "${#contract_scope[@]}" -gt 0 ]; then
  contract_hits=$(grep -rEn 'import anthropic|ANTHROPIC_API_KEY' \
                    --exclude="pre-push" --exclude="lint.yml" \
                    "${contract_scope[@]}" 2>/dev/null \
                  | awk -F: '{
                      content = $0
                      sub(/^[^:]+:[0-9]+:/, "", content)
                      if (content !~ /^[[:space:]]*#/) print
                    }' || true)
  if [ -n "$contract_hits" ]; then
    echo "$contract_hits" >&2
    fail "Anthropic SDK import or ANTHROPIC_API_KEY ref found (see CLAUDE.md §Critique pipeline)"
  else
    ok "critique-pipeline independence (no anthropic SDK / API key)"
  fi
fi

if [ "$failures" -gt 0 ]; then
  echo "" >&2
  echo "$failures pre-push check(s) failed. See CLAUDE.md §Pre-push checks." >&2
  echo "(bypass: git push --no-verify — only if you know why)" >&2
  exit 1
fi

echo "all pre-push checks passed" >&2

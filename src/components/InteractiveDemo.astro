---
import { siteConfig } from "../config";
---

<section id="demo" class="demo-section p-8 sm:p-12 md:p-16 lg:p-24">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold demo-heading">
          Live Demo
        </h2>
        <div
          class="w-[75px] h-[5px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        />
        <p class="demo-subtext mt-4 text-sm sm:text-base">
          Ordinal logistic regression running entirely in your browser. Coefficients calibrated to CMS 2025 measure weights and real-world star distribution.
        </p>
      </div>

      <div class="lg:col-span-8">
        <div class="demo-card p-5 sm:p-8 rounded-2xl border">
          {/* Terminal-style header */}
          <div class="flex items-center gap-2 mb-6">
            <span class="w-3 h-3 rounded-full bg-red-400"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
            <span class="w-3 h-3 rounded-full bg-green-400"></span>
            <span class="demo-terminal-title text-xs font-mono ml-2">star_rating_predictor.py</span>
          </div>

          {/* Input sliders */}
          <div class="space-y-5" id="demo-inputs">
            <div class="demo-input-group">
              <div class="flex items-center justify-between mb-1.5">
                <label class="demo-label text-sm font-medium flex items-center gap-2" for="hedis-rate">
                  HEDIS Composite Rate
                  <span class="demo-weight-badge text-[10px] font-mono px-1.5 py-0.5 rounded">wt 1–3×</span>
                </label>
                <span class="demo-value text-sm font-mono font-bold" id="hedis-rate-val" style={`color: ${siteConfig.accentColor}`}>75%</span>
              </div>
              <input type="range" id="hedis-rate" min="55" max="95" value="75" class="demo-slider w-full" />
              <div class="flex justify-between text-xs demo-range-label mt-0.5">
                <span>55%</span><span>95%</span>
              </div>
            </div>

            <div class="demo-input-group">
              <div class="flex items-center justify-between mb-1.5">
                <label class="demo-label text-sm font-medium flex items-center gap-2" for="cahps-score">
                  CAHPS Member Satisfaction
                  <span class="demo-weight-badge text-[10px] font-mono px-1.5 py-0.5 rounded">wt 2×</span>
                </label>
                <span class="demo-value text-sm font-mono font-bold" id="cahps-score-val" style={`color: ${siteConfig.accentColor}`}>3.5</span>
              </div>
              <input type="range" id="cahps-score" min="2.5" max="4.8" value="3.5" step="0.1" class="demo-slider w-full" />
              <div class="flex justify-between text-xs demo-range-label mt-0.5">
                <span>2.5</span><span>4.8</span>
              </div>
            </div>

            <div class="demo-input-group">
              <div class="flex items-center justify-between mb-1.5">
                <label class="demo-label text-sm font-medium flex items-center gap-2" for="med-adherence">
                  Medication Adherence (D-SNP)
                  <span class="demo-weight-badge demo-weight-triple text-[10px] font-mono px-1.5 py-0.5 rounded">wt 3×</span>
                </label>
                <span class="demo-value text-sm font-mono font-bold" id="med-adherence-val" style={`color: ${siteConfig.accentColor}`}>70%</span>
              </div>
              <input type="range" id="med-adherence" min="50" max="92" value="70" class="demo-slider w-full" />
              <div class="flex justify-between text-xs demo-range-label mt-0.5">
                <span>50%</span><span>92%</span>
              </div>
            </div>

            <div class="demo-input-group">
              <div class="flex items-center justify-between mb-1.5">
                <label class="demo-label text-sm font-medium flex items-center gap-2" for="readmission">
                  Readmission Rate
                  <span class="demo-weight-badge demo-weight-triple text-[10px] font-mono px-1.5 py-0.5 rounded">wt 3× ▼</span>
                </label>
                <span class="demo-value text-sm font-mono font-bold" id="readmission-val" style={`color: ${siteConfig.accentColor}`}>15%</span>
              </div>
              <input type="range" id="readmission" min="8" max="22" value="15" class="demo-slider w-full" />
              <div class="flex justify-between text-xs demo-range-label mt-0.5">
                <span>8%</span><span>22%</span>
              </div>
            </div>
          </div>

          {/* Reward Factor toggle */}
          <div class="demo-reward-row flex items-center justify-between mt-5 px-1">
            <label class="demo-label text-sm font-medium flex items-center gap-2" for="reward-toggle">
              CMS Reward Factor
              <span class="demo-help-tip text-[10px] font-mono px-1.5 py-0.5 rounded cursor-help" title="Plans at ≥4 stars for 3+ consecutive years receive a reward factor of up to +0.4 stars added to their summary rating before final rounding.">?</span>
            </label>
            <div class="flex items-center gap-3">
              <span class="demo-reward-val text-sm font-mono font-bold" id="reward-val" style={`color: ${siteConfig.accentColor}`}>Off</span>
              <label class="demo-toggle-switch">
                <input type="checkbox" id="reward-toggle" />
                <span class="demo-toggle-slider"></span>
              </label>
            </div>
          </div>

          {/* Divider */}
          <div class="demo-divider my-6" />

          {/* Output */}
          <div id="demo-output">
            <div class="flex items-center justify-between mb-4">
              <h3 class="demo-output-title text-sm font-medium uppercase tracking-wider">Predicted Rating</h3>
              <div class="flex items-center gap-2">
                <span class="demo-model-tag text-xs font-mono px-2 py-0.5 rounded">ordinal logistic</span>
              </div>
            </div>

            {/* Star display */}
            <div class="flex items-center gap-4 mb-4">
              <div class="flex gap-1" id="star-display">
                {[1, 2, 3, 4, 5].map((i) => (
                  <svg
                    class="w-8 h-8 sm:w-10 sm:h-10 star-icon transition-all duration-300"
                    data-star={i}
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <span class="text-3xl sm:text-4xl font-bold font-mono" id="rating-number" style={`color: ${siteConfig.accentColor}`}>3.5</span>
            </div>

            {/* Probability bars */}
            <div class="space-y-2" id="prob-bars">
              {[5, 4, 3, 2, 1].map((star) => (
                <div class="flex items-center gap-3">
                  <span class="demo-bar-label text-xs font-mono w-8 text-right">{star}★</span>
                  <div class="demo-bar-track flex-1">
                    <div
                      class="demo-bar-fill transition-all duration-500"
                      data-star-prob={star}
                      style={`width: 0%; background-color: ${siteConfig.accentColor}`}
                    />
                  </div>
                  <span class="demo-bar-pct text-xs font-mono w-10 text-right" data-star-pct={star}>0%</span>
                </div>
              ))}
            </div>

            {/* Cut-point threshold visualization */}
            <div class="mt-6" id="threshold-viz">
              <h4 class="demo-output-title text-xs font-medium uppercase tracking-wider mb-2">Ordinal Thresholds</h4>
              <div class="demo-threshold-container">
                <div class="demo-threshold-track">
                  <div class="demo-threshold-marker" data-threshold="0" title="α₂: ≥2★ cutpoint">
                    <span class="demo-threshold-label">≥2</span>
                  </div>
                  <div class="demo-threshold-marker" data-threshold="1" title="α₃: ≥3★ cutpoint">
                    <span class="demo-threshold-label">≥3</span>
                  </div>
                  <div class="demo-threshold-marker" data-threshold="2" title="α₄: ≥4★ cutpoint">
                    <span class="demo-threshold-label">≥4</span>
                  </div>
                  <div class="demo-threshold-marker" data-threshold="3" title="α₅: ≥5★ cutpoint">
                    <span class="demo-threshold-label">≥5</span>
                  </div>
                  <div class="demo-z-indicator" id="z-indicator" title="Current linear predictor z">
                    <span class="demo-z-label" id="z-label">z</span>
                  </div>
                </div>
                <div class="flex justify-between text-[10px] demo-range-label mt-1">
                  <span>1★ region</span><span>5★ region</span>
                </div>
              </div>
            </div>

            {/* Sensitivity indicators */}
            <div class="mt-5" id="sensitivity-panel">
              <h4 class="demo-output-title text-xs font-medium uppercase tracking-wider mb-2">Marginal Sensitivity</h4>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-2" id="sensitivity-bars">
                <div class="demo-sensitivity-item text-center">
                  <div class="text-[10px] demo-range-label mb-1">HEDIS</div>
                  <div class="text-xs font-mono font-bold" id="sens-hedis" style={`color: ${siteConfig.accentColor}`}>—</div>
                </div>
                <div class="demo-sensitivity-item text-center">
                  <div class="text-[10px] demo-range-label mb-1">CAHPS</div>
                  <div class="text-xs font-mono font-bold" id="sens-cahps" style={`color: ${siteConfig.accentColor}`}>—</div>
                </div>
                <div class="demo-sensitivity-item text-center">
                  <div class="text-[10px] demo-range-label mb-1">Adherence</div>
                  <div class="text-xs font-mono font-bold" id="sens-med" style={`color: ${siteConfig.accentColor}`}>—</div>
                </div>
                <div class="demo-sensitivity-item text-center">
                  <div class="text-[10px] demo-range-label mb-1">Readmit</div>
                  <div class="text-xs font-mono font-bold" id="sens-readmit" style={`color: ${siteConfig.accentColor}`}>—</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <p class="demo-footnote text-xs mt-3">
          Synthetic coefficients calibrated to CMS 2025 measure weights and 2025 MA-PD star distribution. Not trained on contract-level data.
          <a href="/blog/star-rating-predictor-methodology" class="underline hover:opacity-80" style={`color: ${siteConfig.accentColor}`}>Full methodology →</a>
        </p>
      </div>
    </div>
  </div>
</section>


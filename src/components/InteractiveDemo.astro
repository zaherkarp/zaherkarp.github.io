<script>
  document.addEventListener("DOMContentLoaded", () => {
    const hedisSlider = document.getElementById("hedis-rate") as HTMLInputElement;
    const cahpsSlider = document.getElementById("cahps-score") as HTMLInputElement;
    const medSlider = document.getElementById("med-adherence") as HTMLInputElement;
    const readmitSlider = document.getElementById("readmission") as HTMLInputElement;
    const rewardToggle = document.getElementById("reward-toggle") as HTMLInputElement;

    if (!hedisSlider || !cahpsSlider || !medSlider || !readmitSlider) return;

    const hedisVal = document.getElementById("hedis-rate-val")!;
    const cahpsVal = document.getElementById("cahps-score-val")!;
    const medVal = document.getElementById("med-adherence-val")!;
    const readmitVal = document.getElementById("readmission-val")!;
    const rewardVal = document.getElementById("reward-val")!;
    const ratingNum = document.getElementById("rating-number")!;
    const stars = document.querySelectorAll("#star-display .star-icon");

    // ─── CMS-Aligned Ordinal Logistic Regression ───
    //
    // Coefficients calibrated to CMS 2025 measure weights.
    //
    // CMS weight shares (2025 MA-PD):
    //   HEDIS clinical composite: ~12 of 81 weighted pts (15%) — mixed wt 1–3
    //   CAHPS experience:         ~8 of 81 weighted pts (10%) — wt 2 each
    //   Medication adherence:     9 of 81 weighted pts  (11%) — wt 3 × 3 measures
    //   Readmission (PCR):        3 of 81 weighted pts  (4%)  — wt 3 × 1 measure
    //
    // Per-unit weights are scaled so total range contribution is proportional
    // to CMS weight share across each slider's realistic operating range.
    //
    // Target contributions across realistic slider ranges:
    //   HEDIS:     0.08 × 40pp  = 3.2  (37%)
    //   CAHPS:     1.50 × 2.3u  = 3.45 (25%)   ← was 0.9, too low
    //   MedAdh:    0.06 × 42pp  = 2.52 (28%)
    //   Readmit:  -0.08 × 14pp  = 1.12 (10%)   ← was -0.15, too strong
    //
    // Intercepts calibrated to the 2025 MA-PD star distribution:
    //   ~99% of plans ≥2★, ~95% ≥3★, ~42% ≥4★, ~2% 5★
    //   Average overall rating: 3.92 (CMS Fact Sheet, Oct 2024)
    //
    const intercepts = [-10.1, -11.76, -15.1, -18.17]; // α₂, α₃, α₄, α₅
    const weights = {
      hedis: 0.08,          // per percentage point (wt 1–3 composite)
      cahps: 1.50,          // per unit on 2.5–4.8 scale (wt 2, 4 measures)
      medAdherence: 0.06,   // per percentage point (wt 3, triple-weighted)
      readmission: -0.08,   // per percentage point (wt 3, inverse measure)
    };

    // Reward factor: CMS adds 0–0.4 to summary rating for plans at ≥4★
    // for 3+ consecutive years (or showing significant improvement).
    const REWARD_FACTOR = 0.4;

    function sigmoid(x: number): number {
      return 1 / (1 + Math.exp(-x));
    }

    function computeZ(hedis: number, cahps: number, med: number, readmit: number): number {
      return weights.hedis * hedis +
             weights.cahps * cahps +
             weights.medAdherence * med +
             weights.readmission * readmit;
    }

    function computeExpected(z: number): { expected: number; normalized: number[] } {
      const cumProbs = intercepts.map((a) => sigmoid(a + z));

      const probs = [
        1 - cumProbs[0],              // P(Y=1)
        cumProbs[0] - cumProbs[1],     // P(Y=2)
        cumProbs[1] - cumProbs[2],     // P(Y=3)
        cumProbs[2] - cumProbs[3],     // P(Y=4)
        cumProbs[3],                   // P(Y=5)
      ].map((p) => Math.max(0, p));

      const total = probs.reduce((s, p) => s + p, 0);
      const normalized = probs.map((p) => p / total);
      const expected = normalized.reduce((s, p, i) => s + p * (i + 1), 0);
      return { expected, normalized };
    }

    function predict() {
      const hedis = parseFloat(hedisSlider.value);
      const cahps = parseFloat(cahpsSlider.value);
      const med = parseFloat(medSlider.value);
      const readmit = parseFloat(readmitSlider.value);
      const applyReward = rewardToggle?.checked ?? false;

      // Update display values
      hedisVal.textContent = hedis + "%";
      cahpsVal.textContent = cahps.toFixed(1);
      medVal.textContent = med + "%";
      readmitVal.textContent = readmit + "%";
      rewardVal.textContent = applyReward ? `+${REWARD_FACTOR}` : "Off";

      // Linear combination
      const z = computeZ(hedis, cahps, med, readmit);
      const { expected: rawExpected, normalized } = computeExpected(z);

      // Apply reward factor (additive, capped at 5.0)
      const expected = applyReward
        ? Math.min(5.0, rawExpected + REWARD_FACTOR)
        : rawExpected;

      // Update rating number
      ratingNum.textContent = expected.toFixed(1);

      // Update stars
      const fullStars = Math.floor(expected);
      const partial = expected - fullStars;
      stars.forEach((star, i) => {
        star.classList.remove("active", "half");
        if (i < fullStars) {
          star.classList.add("active");
        } else if (i === fullStars && partial >= 0.25) {
          star.classList.add(partial >= 0.75 ? "active" : "half");
        }
      });

      // Update probability bars
      for (let s = 1; s <= 5; s++) {
        const bar = document.querySelector(`[data-star-prob="${s}"]`) as HTMLElement;
        const pct = document.querySelector(`[data-star-pct="${s}"]`) as HTMLElement;
        if (bar && pct) {
          const p = normalized[s - 1] * 100;
          bar.style.width = p + "%";
          pct.textContent = Math.round(p) + "%";
        }
      }

      // ─── Threshold visualization ───
      // Map z to a 0–100% position on the threshold track.
      // The track represents the range from "deep 1★" to "deep 5★".
      // We use the intercept range (negated, since z needs to exceed -α_k)
      // plus some padding.
      const zMin = -intercepts[0] - 5; // well below ≥2★ threshold
      const zMax = -intercepts[3] + 5; // well above ≥5★ threshold
      const zRange = zMax - zMin;

      // Position threshold markers
      for (let t = 0; t < 4; t++) {
        const marker = document.querySelector(`[data-threshold="${t}"]`) as HTMLElement;
        if (marker) {
          const cutZ = -intercepts[t]; // z value where P(Y≥k) = 50%
          const pct = ((cutZ - zMin) / zRange) * 100;
          marker.style.left = Math.max(0, Math.min(100, pct)) + "%";
        }
      }

      // Position z indicator
      const zIndicator = document.getElementById("z-indicator");
      const zLabel = document.getElementById("z-label");
      if (zIndicator && zLabel) {
        const zPct = ((z - zMin) / zRange) * 100;
        zIndicator.style.left = `calc(${Math.max(0, Math.min(100, zPct))}% - 5px)`;
        zLabel.textContent = `z=${z.toFixed(1)}`;
      }

      // ─── Sensitivity analysis ───
      // Marginal effect: ∂E[Y]/∂x ≈ (E[Y|x+δ] - E[Y|x-δ]) / (2δ)
      // Shows how much the predicted rating changes per +1 unit of each input
      const delta = 0.5;
      const sensHedis = (computeExpected(computeZ(hedis + delta, cahps, med, readmit)).expected -
                         computeExpected(computeZ(hedis - delta, cahps, med, readmit)).expected) / (2 * delta);
      const sensCahps = (computeExpected(computeZ(hedis, cahps + delta, med, readmit)).expected -
                         computeExpected(computeZ(hedis, cahps - delta, med, readmit)).expected) / (2 * delta);
      const sensMed =   (computeExpected(computeZ(hedis, cahps, med + delta, readmit)).expected -
                         computeExpected(computeZ(hedis, cahps, med - delta, readmit)).expected) / (2 * delta);
      const sensRead =  (computeExpected(computeZ(hedis, cahps, med, readmit + delta)).expected -
                         computeExpected(computeZ(hedis, cahps, med, readmit - delta)).expected) / (2 * delta);

      const sensEl = (id: string, val: number, suffix: string) => {
        const el = document.getElementById(id);
        if (el) {
          const sign = val >= 0 ? "+" : "";
          el.textContent = `${sign}${val.toFixed(3)}${suffix}`;
        }
      };
      sensEl("sens-hedis", sensHedis, "/pp");
      sensEl("sens-cahps", sensCahps, "/pt");
      sensEl("sens-med", sensMed, "/pp");
      sensEl("sens-readmit", sensRead, "/pp");
    }

    // Bind sliders + reward toggle
    [hedisSlider, cahpsSlider, medSlider, readmitSlider].forEach((slider) => {
      slider.addEventListener("input", predict);
    });
    rewardToggle?.addEventListener("change", predict);

    // Initial prediction
    predict();
  });
</script>

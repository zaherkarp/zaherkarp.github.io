---
import { siteConfig } from "../config";
const hasPresentations = siteConfig.presentations && siteConfig.presentations.length > 0;

// Group presentations by year (descending)
const presentationsByYear = hasPresentations
  ? Object.entries(
      siteConfig.presentations.reduce<Record<number, typeof siteConfig.presentations>>(
        (acc, pres) => {
          (acc[pres.year] = acc[pres.year] || []).push(pres);
          return acc;
        },
        {}
      )
    )
      .sort(([a], [b]) => Number(b) - Number(a))
  : [];
---

{
  hasPresentations && (
    <section id="presentations" class="pres-section p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold pres-heading">
              Presentations
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
            <p class="pres-subtext mt-4 text-sm sm:text-base">
              {siteConfig.presentations.length} presentations across conferences, workshops, and seminars
            </p>
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {presentationsByYear.map(([year, presentations]) => (
                <div>
                  <div class="flex items-center gap-3 mb-4">
                    <span
                      class="text-lg sm:text-xl font-bold font-mono"
                      style={`color: ${siteConfig.accentColor}`}
                    >
                      {year}
                    </span>
                    <div class="flex-1 h-px pres-divider" />
                  </div>

                  <div class="space-y-3">
                    {presentations.map((pres) => (
                      <div class="pres-card p-4 sm:p-5 rounded-xl border transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
                        <h3 class="text-base sm:text-lg font-semibold pres-title">
                          {pres.title}
                        </h3>
                        <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 mt-1.5">
                          <span class="pres-event text-sm font-medium">
                            {pres.event}
                          </span>
                          <span class="hidden sm:inline pres-dot">·</span>
                          <span class="pres-location text-xs sm:text-sm">
                            {pres.location}
                          </span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .pres-section {
    background-color: #f9fafb;
  }
  :global([data-theme="dark"]) .pres-section {
    background-color: #111827;
  }

  .pres-heading {
    color: #111827;
  }
  :global([data-theme="dark"]) .pres-heading {
    color: #f9fafb;
  }

  .pres-subtext {
    color: #6b7280;
  }
  :global([data-theme="dark"]) .pres-subtext {
    color: #9ca3af;
  }

  .pres-divider {
    background-color: #e5e7eb;
  }
  :global([data-theme="dark"]) .pres-divider {
    background-color: #374151;
  }

  .pres-card {
    background-color: #ffffff;
    border-color: #e5e7eb;
  }
  .pres-card:hover {
    border-color: #d1d5db;
  }
  :global([data-theme="dark"]) .pres-card {
    background-color: #1f2937;
    border-color: #374151;
  }
  :global([data-theme="dark"]) .pres-card:hover {
    background-color: #1e293b;
    border-color: #4b5563;
  }

  .pres-title {
    color: #111827;
  }
  :global([data-theme="dark"]) .pres-title {
    color: #f9fafb;
  }

  .pres-event {
    color: #4b5563;
  }
  :global([data-theme="dark"]) .pres-event {
    color: #d1d5db;
  }

  .pres-dot {
    color: #9ca3af;
  }

  .pres-location {
    color: #6b7280;
  }
  :global([data-theme="dark"]) .pres-location {
    color: #9ca3af;
  }
</style>
